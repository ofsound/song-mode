{
  "name": "song-mode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "electron:dev": "node electron/dev.mjs",
    "electron:start": "npm run build && SONG_MODE_ELECTRON_USE_PRODUCTION_SERVER=1 electron electron/main.mjs",
    "electron:pack": "npm run build && electron-builder --mac dir",
    "electron:dist": "npm run build && electron-builder --mac zip",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "verify": "npm run check && npm run typecheck && npm run test && npm run knip"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "1.168.22",
    "@tanstack/react-start": "1.167.41",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "idb": "^8.0.3",
    "lucide-react": "^0.545.0",
    "nitro": "3.0.260415-beta",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "0.6.0",
    "@tanstack/react-devtools": "0.10.2",
    "@tanstack/react-router-devtools": "1.166.13",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "fake-indexeddb": "6.2.5",
    "jsdom": "^28.1.0",
    "knip": "^6.4.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.5"
  },
  "build": {
    "appId": "com.songmode.app",
    "productName": "Song Mode",
    "directories": {
      "output": "dist/electron"
    },
    "electronDist": "node_modules/electron/dist",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".output",
        "to": ".output"
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dir",
        "zip"
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": null,
        "NSCameraUsageDescription": null,
        "NSAudioCaptureUsageDescription": null,
        "NSBluetoothPeripheralUsageDescription": null,
        "NSBluetoothAlwaysUsageDescription": null
      }
    }
  }
}
